# BuzzyBee Workstation env
# Copy to .env and fill in values. .env is gitignored.

# --- Server-side (node scripts only — never ship to client) ---
# Supabase database connection URL (Project Settings → Database → URI, Session pooler / port 5432)
SUPABASE_DB_URL=postgresql://postgres.bsjplzpoynsnluihmnul:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# --- Client-side (Vite, exposed in built JS — anon/publishable key only, never service_role) ---
VITE_SUPABASE_URL=https://bsjplzpoynsnluihmnul.supabase.co
# Either of the two names works; use whichever Supabase shows you in dashboard:
#   - Older projects: anon key (eyJhbGc...)
#   - Newer projects: publishable key (sb_publishable_...)
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key-here
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# GIF picker in Comms (Giphy). Free key: https://developers.giphy.com → Create App → API Key.
# Without it, the GIF button is hidden. Add the same value to Netlify env vars for the deploy.
VITE_GIPHY_KEY=

# TURN relay for WebRTC (huddles + guest meeting links). Without it, calls are
# STUN-only — fine on normal networks, but fails for guests behind strict NAT.
# Free tiers: metered.ca, Cloudflare. Add the same vars to Netlify.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
