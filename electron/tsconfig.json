{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-main",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["main/**/*.ts", "preload/**/*.ts", "shared/**/*.ts"],
  "exclude": ["renderer", "node_modules", "dist-main", "dist-renderer"]
}
