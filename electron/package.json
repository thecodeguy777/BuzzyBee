{
  "name": "hivemind-ai",
  "productName": "BuzzyHive AI",
  "version": "1.0.0",
  "description": "BuzzyHive AI — Meeting intelligence for VA-client partnerships",
  "author": "BuzzyHive",
  "main": "dist-main/main/index.js",
  "scripts": {
    "dev": "concurrently -n main,renderer -c blue,green \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.json && electron . --dev",
    "dev:renderer": "vite --config ../vite.config.electron.ts",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build --config ../vite.config.electron.ts",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:portable": "npm run build && electron-builder --win portable --x64",
    "package:win": "npm run build && electron-packager . \"BuzzyHive AI\" --platform=win32 --arch=x64 --out=release --overwrite --asar --prune --ignore=\"^/(release|main|preload|shared|renderer|tsconfig\\\\.json|electron-builder.*)\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@signalwire/js": "^3.30.0",
    "@supabase/supabase-js": "^2.105.1",
    "dotenv": "^17.4.2",
    "electron-store": "^8.2.0",
    "sip.js": "^0.21.2"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.1.0",
    "daisyui": "^5.5.19",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.3",
    "vue": "^3.5.30"
  },
  "build": {
    "appId": "co.hivemind.ai",
    "productName": "BuzzyHive AI",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-main/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "BuzzyHive-AI-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BuzzyHive AI"
    },
    "asar": true
  }
}
